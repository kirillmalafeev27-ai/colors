# Скопируйте в .env (для локального запуска) или задайте на Render → Environment.
# Обязательный:
ELEVENLABS_API_KEY=ваш_ключ_от_elevenlabs

# Необязательные (можно не указывать):
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb   # Voice ID из кабинета ElevenLabs
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5      # или eleven_multilingual_v2
# ELEVENLABS_LANG=de                          # язык
